# ─── Auth (Clerk) ─────────────────────────────────────────────
# https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Optional: where Clerk sends users for sign-in/up and after auth
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Dev-only convenience: set to a userId (e.g. "demo-user") to bypass Clerk
# locally and view seeded data without configuring auth. Ignored in production.
# DEV_USER_ID=demo-user

# ─── Database (Turso / libSQL) ────────────────────────────────
# Local dev uses a plain SQLite file — no token needed.
# Prod: turso db create tally → turso db show tally --url
#       turso db tokens create tally
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# ─── Receipt image storage (Vercel Blob) ──────────────────────
# Vercel dashboard → Storage → Blob → create store → read/write token
BLOB_READ_WRITE_TOKEN=

# ─── AI · Claude (Anthropic) ──────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── AI · Gemini (default reader for the Exact engine) ────────
# Free key from https://aistudio.google.com → Get API key.
# Used to read receipts on the default (Exact) flow — accurate and free.
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

# ─── AI · Groq ────────────────────────────────────────────────
# https://console.groq.com → API Keys.
# Model ids live here so they stay swappable when Groq rotates models.
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_LOGIC_MODEL=openai/gpt-oss-120b

# ─── Rate limiting (Upstash Redis REST) ───────────────────────
# https://console.upstash.com → Redis → create database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
